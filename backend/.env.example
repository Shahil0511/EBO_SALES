# Copy to .env and fill in real values. Commit THIS file, never .env.
ENV=local
LOG_LEVEL=INFO

# Unicorn warehouse — READ-ONLY access
DB_HOST=10.150.0.5
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=Unicorn

# Connection pool / safety
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_STATEMENT_TIMEOUT_MS=30000
